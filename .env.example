# Variáveis do docker-compose (copie para .env e preencha)

# Telegram — notificações do Alertmanager
# Token do bot (via @BotFather)
TELEGRAM_BOT_TOKEN=
# Chat ID de destino (conversa privada, grupo ou canal).
# Para descobrir: mande /start pro bot e rode:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
