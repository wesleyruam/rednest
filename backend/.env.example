# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
# Comma-separated list of allowed CORS origins (the Vite frontend)
CORS_ORIGINS=http://localhost:5173

# ─── Database ───────────────────────────────────────────────────────────────
# Matches docker-compose.yml
DATABASE_URL="postgresql://rednest:rednest@localhost:5432/rednest?schema=public"

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-in-production
JWT_REFRESH_TTL=7d

# ─── API Keys ───────────────────────────────────────────────────────────────
API_KEY_PREFIX=rn_live_

# Segredo para criptografar as chaves de provedores externos (AES-256-GCM)
INTEGRATIONS_SECRET=change-me-integrations-secret-in-production

# Redis (fila BullMQ do monitoramento)
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenTelemetry (tracing)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=rednest-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

# ─── Rate limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Seed (default admin created by prisma db seed) ─────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@rednest.local
SEED_ADMIN_PASSWORD=admin123
