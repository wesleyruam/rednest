{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "title": "RedNest — Visão Geral",
  "uid": "rednest-overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Taxa de requisições HTTP (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(rednest_http_request_duration_seconds_count[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência HTTP p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rednest_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Fila de monitores (BullMQ)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rednest_monitor_queue_jobs",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Recursos do processo",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [
        { "matcher": { "id": "byName", "options": "Memória (MB)" }, "properties": [ { "id": "unit", "value": "decmbytes" } ] }
      ] },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "Memória (MB)"
        },
        {
          "refId": "B",
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "CPU (cores)"
        }
      ]
    }
  ]
}
